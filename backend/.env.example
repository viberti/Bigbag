# ─────────────────────────────────────────────────────────────
# Bigbag backend — exemplo de variáveis de ambiente.
# Copiar para `.env` (chmod 600) e preencher com valores reais.
# O `.env` NUNCA é versionado. Este ficheiro NÃO contém segredos.
# ─────────────────────────────────────────────────────────────

# Servidor
PORT=4200
NODE_ENV=development

# Base de dados (MySQL local do host — BD própria do projeto)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=app_bigbag
DB_USER=bigbag
DB_PASSWORD=

# IA — OpenRouter (uma só chave cobre texto/imagem/áudio)
OPENROUTER_API_KEY=
# Modelo geral (consulta, canonicalização, extração de PDF-texto): barato
OPENROUTER_MODEL=google/gemini-2.5-flash-lite
# Extração de fatura por IMAGEM (VLM): modelo mais forte (precisão)
OPENROUTER_MODEL_EXTRACAO=google/gemini-2.5-flash
# Transcrição de voz (áudio sensível)
OPENROUTER_STT_MODEL=google/gemini-2.5-flash
OPENROUTER_TIMEOUT_MS=20000
# Auto-correção da extração: nº máx. de re-tentativas quando não reconcilia (0 = desligado)
OPENROUTER_MAX_CORRECOES=2

# Autenticação — Google OAuth (servidor exposto à internet; ver Conceito §7)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=
SUPERUSER_EMAIL=
SESSION_SECRET=

# Uploads (produção: /var/lib/bigbag/...)
UPLOAD_DIR_FATURAS=./uploads/comprovantes
UPLOAD_DIR_VOZ=./uploads/notas_voz

# Lidl Plus — faturas digitais com EAN por linha (API não-oficial).
# O refresh token obtém-se UMA vez, fora do Bigbag:
#   python -m lidlplus -c PT -l pt --2fa phone auth   (browser+password+OTP → token)
# Só o token (não a password) vive aqui. É um SEGREDO.
LIDLPLUS_REFRESH_TOKEN=
LIDLPLUS_COUNTRY=PT
LIDLPLUS_LANGUAGE=pt
